# ====================================
# Jobs Service Configuration
# ====================================
# Copy this file to .env and fill in the actual values

# ====== API ======
API_URL=http://api:8000

# ====== AUTH ======
API_CLIENT_ID=jobs-worker
API_CLIENT_SECRET=your-jobs-worker-secret

# ====== REDIS ======
REDIS_URL=redis://redis:6379/0

# ====== OPEN METEO ======
# Location for Open Meteo weather data
OPEN_METEO_LATITUDE=37.7749
OPEN_METEO_LONGITUDE=-122.4194

# ====== LOGGING ======
# Log level: TRACE|DEBUG|INFO|WARNING|ERROR|CRITICAL
LOG_LEVEL=INFO
# Log format: json or colored
LOG_FORMAT=json
